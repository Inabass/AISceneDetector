AISD_APP_NAME=AI Scene Detector
AISD_ENVIRONMENT=local
AISD_HOST=127.0.0.1
AISD_PORT=8000
AISD_LOG_LEVEL=INFO
AISD_STORAGE_ROOT=data
AISD_DATABASE_URL=sqlite:///data/app.db
AISD_CUDA_ENABLED=true
AISD_CPU_DIAGNOSTIC_ENABLED=false
AISD_DEFAULT_TRAINING_BATCH_SIZE=64
AISD_DEFAULT_DETECTION_BATCH_SIZE=64
AISD_AUTO_BATCH_REDUCTION=true
# AISD_FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
# AISD_FFPROBE_PATH=C:\ffmpeg\bin\ffprobe.exe
